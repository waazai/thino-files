{
  "name": "thino-files",
  "version": "0.7.1",
  "description": "Twitter-style timeline for Obsidian where every post is its own Markdown file with YAML frontmatter",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "version": "node version-bump.mjs && git add manifest.json",
    "release": "git push --follow-tags && ./release.sh",
    "ship": "npm version patch && npm run release"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "timeline"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "obsidian": "^1.5.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
